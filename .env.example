SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Nuxt
NUXT_SECRET=
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# GitHub (pour les liens "Modifier sur GitHub" dans les docs)
GITHUB_REPO_URL=https://github.com/username/dngblog
